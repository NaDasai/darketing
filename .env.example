# ==============================================================================
# Eagle Eyes — master env reference.
# This file documents every variable used across the monorepo.
# Each app reads its own copy: see apps/backend/.env.example and
# apps/frontend/.env.local.example. Values below are safe defaults for local dev.
# ==============================================================================

# --- Database ------------------------------------------------------------------
# Local MongoDB 7 (standalone, no replica set required with Mongoose).
MONGODB_URI=mongodb://localhost:27017/eagle-eyes

# --- Redis (BullMQ) ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- OpenRouter (LLM) ----------------------------------------------------------
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Free model default. Swap for any OpenRouter model id.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers recommended by OpenRouter.
OPENROUTER_APP_NAME=Eagle Eyes
OPENROUTER_APP_URL=http://localhost:3000

# --- Pipeline ------------------------------------------------------------------
CRON_SCHEDULE=0 6 * * *
DEFAULT_TOP_N=5
LLM_RATE_LIMIT_PER_SEC=10
RSS_FETCH_TIMEOUT_MS=10000
RSS_FETCH_RETRIES=2
WORKER_CONCURRENCY=2

# --- Backend server ------------------------------------------------------------
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# --- Frontend ------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
