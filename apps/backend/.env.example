# Backend environment — copy to apps/backend/.env and fill in OPENROUTER_API_KEY.

# Database
MONGODB_URI=mongodb://localhost:27017/darketing

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Darketing
OPENROUTER_APP_URL=http://localhost:3000

# Pipeline
CRON_SCHEDULE=0 6 * * *
DEFAULT_TOP_N=5
LLM_RATE_LIMIT_PER_SEC=0.3
RSS_FETCH_TIMEOUT_MS=10000
RSS_FETCH_RETRIES=2
WORKER_CONCURRENCY=2

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
