    "fastify-type-provider-zod": "^2.0.0",
    "ioredis": "^5.4.1",
    "mongoose": "^8.8.0",
    "node-cron": "^3.0.3",
    "p-limit": "^6.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
